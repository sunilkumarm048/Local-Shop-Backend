# Server
NODE_ENV=development
PORT=4000

# Frontend origin (for CORS + Socket.IO)
CLIENT_ORIGIN=http://localhost:3000

# MongoDB (use MongoDB Atlas free tier in production)
MONGODB_URI=mongodb://localhost:27017/localshop

# Redis (Upstash, Redis Cloud, or local). Required for Socket.IO scaling.
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Razorpay (test keys; switch to live before launch)
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx

# MSG91 (phone OTP for India). Cheaper + DLT-compliant.
MSG91_AUTH_KEY=xxx
MSG91_TEMPLATE_ID=xxx
MSG91_SENDER_ID=LCLSHP

# Google OAuth (for Auth.js on the frontend; backend just trusts the JWT)
GOOGLE_CLIENT_ID=xxx
GOOGLE_CLIENT_SECRET=xxx

# Google Maps server-side key (geocoding, distance matrix)
GOOGLE_MAPS_API_KEY=xxx
